---
import RootLayout from '../layouts/RootLayout.astro';
import DesktopLayout from '../layouts/DesktopLayout.astro';
import SafeModeShell from '../layouts/SafeModeShell.astro';
import Wallpaper from '../components/desktop/Wallpaper.astro';
import DesktopIcon from '../components/desktop/DesktopIcon.astro';
import { Taskbar } from '../components/taskbar/Taskbar';
import { WindowLayer } from '../components/window/WindowLayer';
import SafeModeManager from '../components/mobile/SafeModeManager';
import ModeContainer from '../components/desktop/ModeContainer';
---

<RootLayout>
  <!-- Noscript fallback: renders when JavaScript is disabled -->
  <noscript>
    <div class="noscript-fallback">
      <p>This portfolio site uses JavaScript for the full interactive experience. Here are the projects available:</p>
      <ul>
        <li><a href="https://github.com/mansyar/chasing-chapters-v2">Chasing Chapters</a></li>
        <li><a href="https://github.com/mansyar/tubular-bexus-osw">Tubular Bexus OSW</a></li>
        <li><a href="https://github.com/mansyar/icarus-server-manager">Icarus Server Manager</a></li>
      </ul>
    </div>
  </noscript>

  <!-- Inline noscript fallback styles -->
  <style is:inline>
    .noscript-fallback {
      padding: 2rem;
      font-family: Tahoma, sans-serif;
      color: #fff;
      background: #0a246a;
    }
    .noscript-fallback ul {
      list-style: disc;
      padding-left: 1.5rem;
    }
    .noscript-fallback a {
      color: #4aa5ff;
    }
  </style>

  <ModeContainer client:load>
    {/* Safe Mode Shell — Visible on Mobile (< 768px) */}
    <div class="block md:group-[.force-desktop]:hidden md:hidden">
      <SafeModeShell>
        <SafeModeManager client:load />
      </SafeModeShell>
    </div>

    {/* Standard XP Desktop — Visible on Desktop (>= 768px) or when Forced */}
    <div class="hidden md:block md:group-[.force-desktop]:block group-[.force-desktop]:block">
      <DesktopLayout>
        <div id="wallpaper-area" class="absolute inset-0 z-0">
          <Wallpaper />
        </div>

        <div id="desktop-icons" class="absolute left-6 top-5 z-10 flex flex-col gap-4">
          <DesktopIcon
            icon="/icons/my-computer.svg"
            label="My Computer"
            windowId="explorer"
          />
          <DesktopIcon
            icon="/icons/my-documents.svg"
            label="My Documents"
            windowId="mydocs"
          />
          <DesktopIcon
            icon="/icons/help-support.svg"
            label="Knowledge Base"
            windowId="help"
          />
          <DesktopIcon
            icon="/icons/command-prompt.svg"
            label="Command Prompt"
            windowId="cmd"
          />
          <DesktopIcon
            icon="/icons/recycle-bin.svg"
            label="Recycle Bin"
            windowId="recyclebin"
          />
        </div>

        <div id="window-layer" class="absolute inset-0 z-20" style="pointer-events: none">
          <WindowLayer client:only="react" />
        </div>

        <div id="taskbar" class="absolute bottom-0 left-0 right-0 z-50">
          <Taskbar client:only="react" />
        </div>
      </DesktopLayout>
    </div>
  </ModeContainer>
</RootLayout>
