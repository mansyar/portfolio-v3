---
export interface Props {
  icon: string;
  label: string;
  windowId: string;
}

const { icon, label, windowId } = Astro.props;
---

<div
  class="desktop-icon"
  data-window-id={windowId}
  data-window-label={label}
>
  <img
    src={icon}
    alt={label}
    width="48"
    height="48"
    class="desktop-icon__img"
    aria-hidden="true"
  />
  <span class="desktop-icon__label">{label}</span>
</div>

<style>
  .desktop-icon {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: var(--xp-icon-width, 72px);
    cursor: pointer;
    padding: 4px;
    border-radius: 4px;
    user-select: none;
  }

  .desktop-icon:hover {
    background-color: var(--xp-blue-highlight);
    outline: 1px solid rgba(255, 255, 255, 0.3);
  }

  .desktop-icon__img {
    display: block;
  }

  .desktop-icon__label {
    display: block;
    font-family: var(--xp-font-family);
    font-size: var(--xp-icon-font-size);
    color: var(--xp-icon-text-color);
    text-shadow: var(--xp-icon-text-shadow);
    text-align: center;
    margin-top: 2px;
    line-height: 1.15;
    max-width: 72px;
    word-wrap: break-word;
    overflow-wrap: break-word;
  }
</style>
